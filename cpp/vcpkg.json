{
  "name": "arcticdb",
  "version": "1.2.0",
  "dependencies": [
    "fmt",
    "spdlog",
    "pcre2",
    "unordered-dense",
    "boost-thread",
    {
      "name": "xxhash",
      "$version reason": "Must match version in conda build for interoperability"
    },
    {
      "name": "protobuf",
      "default-features": false,
      "features": [ "zlib" ]
    },
    {
      "name": "folly",
      "default-features": false,
      "features": [ "lz4" ]
    },
    "zstd",
    {
      "name": "prometheus-cpp",
      "default-features": false,
      "features": [ "push", "pull" ]
    },
    "mongo-cxx-driver",
    {
      "name": "aws-sdk-cpp",
      "$version reason": "Version which contains atomic put operations",
      "default-features": false,
      "features": [ "s3", "identity-management" ]
    },
    "aws-crt-cpp",
    "aws-c-mqtt",
    "aws-c-s3",
    "aws-c-io",
    "aws-c-common",
    "aws-c-auth",
    "aws-c-cal",
    "aws-c-http",
    "aws-c-sdkutils",
    "aws-c-event-stream",
    "aws-checksums",
    "boost-dynamic-bitset",
    "boost-interprocess",
    "boost-callable-traits",
    "boost-circular-buffer",
    "boost-optional",
    "boost-multiprecision",
    "bitmagic",
    "openssl",
    "double-conversion",
    "libevent",
    "gtest",
    "rapidcheck",
    {
      "name": "arrow",
      "default-features": false
    },
    {
      "name": "azure-core-cpp",
      "default-features": false,
      "features": [ "winhttp" ],
      "platform": "windows"
    },
    {
      "name": "curl",
      "version>=": "8.18.0",
      "$version reason": "Issues with libcurl==8.17.0 which need investigation"
    },
    {
      "name": "azure-core-cpp",
      "default-features": false,
      "features": [ "curl" ],
      "platform": "!windows"
    },
    "azure-identity-cpp",
    "azure-storage-blobs-cpp",
    "benchmark",
    "arcticdb-sparrow"
  ],
  "overrides": [
    { "name": "openssl", "version-string": "3.3.0" },
    { "name": "arcticdb-sparrow", "version": "2.4.0" },
    { "name": "arrow", "version": "21.0.0#2" },
    { "name": "aws-sdk-cpp", "version": "1.11.820", "$note": "Update overlay json to upgrade." },
    { "name": "aws-crt-cpp", "version": "0.39.1" },
    { "name": "aws-c-mqtt", "version": "0.15.2" },
    { "name": "aws-c-s3", "version": "0.12.4" },
    { "name": "aws-c-io", "version": "0.26.3" },
    { "name": "aws-c-common", "version": "0.13.1" },
    { "name": "aws-c-auth", "version": "0.10.3" },
    { "name": "aws-c-cal", "version": "0.9.14" },
    { "name": "aws-c-http", "version": "0.11.0" },
    { "name": "aws-c-sdkutils", "version": "0.2.4" },
    { "name": "aws-c-event-stream", "version": "0.7.1" },
    { "name": "aws-checksums", "version": "0.2.10" },
    { "name": "azure-core-cpp", "version": "1.12.0" },
    { "name": "azure-identity-cpp", "version": "1.6.0" },
    { "name": "benchmark", "version": "1.9.0" },
    { "name": "bitmagic", "version": "7.12.3" },
    { "name": "double-conversion", "version": "3.2.1" },
    { "name": "fmt", "version": "12.1.0" },
    { "name": "folly", "version-string": "2026.02.23.00" },
    { "name": "gflags", "version": "2.2.2#5" },
    { "name": "glog", "version": "0.6.0#2" },
    { "name": "gtest", "version": "1.12.1" },
    { "name": "libbson", "version": "1.30.3" },
    { "name": "libevent", "version": "2.1.12#7" },
    { "name": "lz4", "version": "1.9.3#4" },
    { "name": "mongo-c-driver", "version": "1.28.0" },
    { "name": "mongo-cxx-driver", "version": "3.10.2#1" },
    { "name": "prometheus-cpp", "version": "1.1.0" },
    { "name": "protobuf", "version": "3.21.8" },
    { "name": "rapidcheck", "version": "2023-12-14" },
    { "name": "s2n", "version": "1.7.3" },
    { "name": "spdlog", "version": "1.17.0" },
    { "name": "thrift", "version": "0.22.0#2" },
    { "name": "xxhash", "version": "0.8.2" },
    { "name": "zlib", "version": "1.3.1" },
    { "name": "zstd", "version": "1.5.2" }
  ],
  "vcpkg-configuration": {
    "overlay-ports": ["third_party/vcpkg_overlays"]
  },
  "$note on builtin-baseline": "Remember to regenerate third_party/vcpkg_overlays",
  "builtin-baseline": "cea592f4772491abdb7c483387a59ea89889f4be"
}
